{
  "name": "interview-mate-ai",
  "version": "1.0.0",
  "description": "Production desktop client for Interview Mate AI.",
  "author": {
    "name": "Interview Mate AI"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite --host localhost\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:native-stealth": "node-gyp rebuild --directory native/stealth-bridge",
    "build:desktop": "npm run build && node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
    "build:desktop:prod": "npm run build && node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.prod.json",
    "pack": "npm run build:desktop:prod && electron-builder --dir",
    "dist": "npm run build:desktop:prod && electron-builder",
    "build:win": "npm run build:desktop:prod && electron-builder --win nsis portable",
    "build:mac": "npm run build:desktop:prod && electron-builder --mac dmg zip",
    "postinstall": "electron-builder install-app-deps",
    "desktop": "electron .",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "axios": "^1.13.2",
    "firebase": "^12.15.0",
    "highlight.js": "^11.11.1",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vue3-google-login": "^2.1.4"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.15.3",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.5",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "build": {
    "appId": "ai.interviewmate.desktop",
    "productName": "Interview Mate AI",
    "copyright": "Copyright © 2026 Interview Mate AI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "native/stealth-bridge/build/Release/*.node",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "native/stealth-bridge/build/Release",
        "to": "native/stealth-bridge/build/Release",
        "filter": [
          "*.node"
        ]
      }
    ],
    "npmRebuild": true,
    "asar": true,
    "asarUnpack": [
      "native/stealth-bridge/build/Release/*.node"
    ],
    "artifactName": "InterviewMateAI-${version}-${os}.${ext}",
    "publish": null,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "InterviewMateAI-Windows-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "dmg": {
      "artifactName": "InterviewMateAI-macOS-${version}.${ext}"
    }
  }
}
